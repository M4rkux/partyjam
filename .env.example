# Database
# Local (docker-compose): postgresql://partyjam:partyjam@127.0.0.1:5432/partyjam
# Production (Neon): postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://partyjam:partyjam@127.0.0.1:5432/partyjam

# Spotify OAuth
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/api/auth/callback

# App
ORIGIN=http://127.0.0.1:5173
